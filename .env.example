# SQLite file path (relative to project root)
DATABASE_URL=./data/notetaker.db

# Auth — single user
AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
AUTH_EMAIL=you@example.com
# bcrypt hash of your password — generate with: npm run hash:password -- "yourpassword"
AUTH_PASSWORD_HASH=

# File storage: "local" or "r2"
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./data/uploads

# Cloudflare R2 (only required when STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
